<div class="adm-page">
  <div class="card mb-3">
    <div class="card-header"><h3 class="card-title"><i class="ti ti-settings me-2"></i>IT资产管控 — 连接配置</h3></div>
    <div class="card-body">
      <form method="post" action="" enctype="multipart/form-data">
        <input type="hidden" name="_glpi_csrf_token" value="{{ csrf_token }}">

        <h5 class="border-bottom pb-2">Active Directory 连接</h5>
        <div class="row g-3">
          <div class="col-md-6">
            <label class="form-label">域控主机 / IP</label>
            <input type="text" name="ad_host" class="form-control" value="{{ config.ad_host }}" placeholder="192.168.1.10">
          </div>
          <div class="col-md-2">
            <label class="form-label">端口</label>
            <input type="number" name="ad_port" class="form-control" value="{{ config.ad_port }}">
          </div>
          <div class="col-md-4 d-flex align-items-end pb-1">
            <div class="form-check form-switch">
              <input type="hidden" name="ad_use_ssl" value="0">
              <input class="form-check-input" type="checkbox" name="ad_use_ssl" value="1" id="use_ssl" {{ config.ad_use_ssl == '1' ? 'checked' : '' }}>
              <label class="form-check-label" for="use_ssl">启用 LDAPS（636）</label>
            </div>
          </div>
          <div class="col-12">
            <label class="form-label">Base DN</label>
            <input type="text" name="ad_base_dn" class="form-control" value="{{ config.ad_base_dn }}" placeholder="DC=corp,DC=com">
          </div>

          <div class="mb-3">
            <label class="form-label fw-bold">用户搜索 OU
              <span class="text-muted fw-normal small">（多个用英文逗号分隔，留空则搜索整个域）</span>
            </label>
            <input type="text" name="ad_user_ous" class="form-control font-monospace"
                   value="{{ config.ad_user_ous }}"
                   placeholder="OU=员工,DC=corp,DC=com,OU=外包,DC=corp,DC=com">
            <div class="form-text text-muted">
              只搜索指定 OU 下的用户，跳过系统容器（Domain Controllers 等），有效减少查询量。
            </div>
          </div>

          <div class="mb-3">
            <label class="form-label fw-bold">计算机搜索 OU
              <span class="text-muted fw-normal small">（多个用英文逗号分隔，留空则搜索整个域）</span>
            </label>
            <input type="text" name="ad_computer_ous" class="form-control font-monospace"
                   value="{{ config.ad_computer_ous }}"
                   placeholder="OU=Workstations,DC=corp,DC=com,OU=Laptops,DC=corp,DC=com">
            <div class="form-text text-muted">
              只搜索指定 OU 下的计算机，避免将 Domain Controllers 等服务器纳入统计。
            </div>
          </div>
          <div class="col-md-6">
            <label class="form-label">绑定账户 DN</label>
            <input type="text" name="ad_bind_dn" class="form-control" value="{{ config.ad_bind_dn }}">
          </div>
          <div class="col-md-6">
            <label class="form-label">绑定密码 <small class="text-muted">（加密存储，留空不修改）</small></label>
            <input type="password" name="ad_password" class="form-control" placeholder="{{ config.ad_password ? '已设置' : '请输入' }}">
          </div>
          <div class="col-12">
            <label class="form-label fw-bold">CA 证书 <small class="text-muted fw-normal">（启用 LDAPS 时需要配置）</small></label>

            {% if cert_files is not empty %}
            <div class="mb-2">
              <label class="form-label small">选择已有证书</label>
              <select name="ad_ca_cert_select" class="form-select form-select-sm">
                <option value="">— 不选择（保持当前）—</option>
                {% for f in cert_files %}
                  <option value="{{ f }}" {% if config.ad_ca_cert == f %}selected{% endif %}>
                    {{ f }}{% if config.ad_ca_cert == f %} ✓ 当前使用{% endif %}
                  </option>
                {% endfor %}
              </select>
              {% if config.ad_ca_cert %}
                <div class="form-text text-success">
                  <i class="ti ti-check me-1"></i>当前使用：{{ config.ad_ca_cert }}
                </div>
              {% endif %}
            </div>
            <div class="text-muted small mb-1">或上传新证书：</div>
            {% else %}
              {% if config.ad_ca_cert %}
                <div class="form-text text-success mb-1"><i class="ti ti-check me-1"></i>当前使用：{{ config.ad_ca_cert }}</div>
              {% else %}
                <div class="form-text text-muted mb-1">暂无已有证书，请上传</div>
              {% endif %}
            {% endif %}

            <input type="file" name="ad_ca_cert" class="form-control form-control-sm"
                   accept=".pem,.crt,.cer,.p7b,.p7c">
            <div class="form-text text-muted">支持格式：.pem .crt .cer .p7b .p7c；上传后自动保存到服务器 certificates 目录</div>
          </div>
        </div>
        <div class="mt-2">
          <button type="button" class="btn btn-sm btn-outline-secondary" onclick="testConn('ad')">测试 AD 连接</button>
          <span id="test_ad_result" class="ms-2 small"></span>
        </div>

        <h5 class="border-bottom pb-2 mt-4">FastAPI 服务端</h5>
        <div class="row g-3">
          <div class="col-md-8">
            <label class="form-label">FastAPI URL</label>
            <input type="text" name="fastapi_url" class="form-control" value="{{ config.fastapi_url }}" placeholder="http://172.29.147.120/agent">
          </div>
          <div class="col-md-2">
            <label class="form-label">超时（秒）</label>
            <input type="number" name="fastapi_timeout" class="form-control" value="{{ config.fastapi_timeout }}">
          </div>
          <div class="col-12">
            <label class="form-label">API Token <small class="text-muted">（加密存储，留空不修改）</small></label>
            <input type="password" name="fastapi_token" class="form-control" placeholder="{{ config.fastapi_token ? '已设置' : '请输入' }}">
          </div>
        </div>
        <div class="mt-2">
          <button type="button" class="btn btn-sm btn-outline-secondary" onclick="testConn('fastapi')">测试 FastAPI 连接</button>
          <span id="test_fastapi_result" class="ms-2 small"></span>
        </div>


        <h5 class="border-bottom pb-2 mt-4">
          <i class="ti ti-brand-wechat me-2"></i>通讯平台配置
          <small class="text-muted fw-normal fs-6 ms-2">企业微信 / 钉钉 / 飞书</small>
        </h5>

        {# ── 企业微信 ── #}
        <div class="card mb-3 border-secondary">
          <div class="card-header py-2 d-flex align-items-center gap-2">
            <div class="form-check form-switch mb-0">
              <input class="form-check-input" type="checkbox" name="wecom_enabled" value="1" id="wecom_enabled"
                     {{ config.wecom_enabled == '1' ? 'checked' : '' }}>
              <label class="form-check-label fw-semibold" for="wecom_enabled">
                <i class="ti ti-brand-wechat text-success me-1"></i>企业微信
              </label>
            </div>
            <button type="button" class="btn btn-xs btn-outline-secondary ms-auto"
                    onclick="testIMConn('wecom')">测试连接</button>
            <span id="test_wecom_result" class="small"></span>
          </div>
          <div class="card-body">
            <div class="row g-3">
              <div class="col-md-4">
                <label class="form-label">企业 ID（CorpID）</label>
                <input type="text" name="wecom_corpid" class="form-control form-control-sm font-monospace"
                       value="{{ config.wecom_corpid }}" placeholder="ww1234567890abcdef">
              </div>
              <div class="col-md-4">
                <label class="form-label">应用 Secret <small class="text-muted">（加密存储，留空不修改）</small></label>
                <input type="password" name="wecom_corpsecret" class="form-control form-control-sm"
                       placeholder="{{ config.wecom_corpsecret ? '已设置' : '请输入' }}">
              </div>
              <div class="col-md-4">
                <label class="form-label">AgentID（应用ID）</label>
                <input type="text" name="wecom_agentid" class="form-control form-control-sm font-monospace"
                       value="{{ config.wecom_agentid }}" placeholder="1000001">
              </div>
            </div>
            <div class="form-text text-muted mt-1">
              前往 <a href="https://work.weixin.qq.com/wework_admin/frame#apps" target="_blank">企业微信管理后台 → 应用管理</a>
              自建应用获取以上信息，并开启「通讯录」权限。
            </div>
          </div>
        </div>

        {# ── 钉钉 ── #}
        <div class="card mb-3 border-secondary">
          <div class="card-header py-2 d-flex align-items-center gap-2">
            <div class="form-check form-switch mb-0">
              <input class="form-check-input" type="checkbox" name="dingtalk_enabled" value="1" id="dingtalk_enabled"
                     {{ config.dingtalk_enabled == '1' ? 'checked' : '' }}>
              <label class="form-check-label fw-semibold" for="dingtalk_enabled">
                <i class="ti ti-brand-dingtalk text-primary me-1"></i>钉钉
              </label>
            </div>
            <button type="button" class="btn btn-xs btn-outline-secondary ms-auto"
                    onclick="testIMConn('dingtalk')">测试连接</button>
            <span id="test_dingtalk_result" class="small"></span>
          </div>
          <div class="card-body">
            <div class="row g-3">
              <div class="col-md-4">
                <label class="form-label">AppKey（Client ID）</label>
                <input type="text" name="dingtalk_appkey" class="form-control form-control-sm font-monospace"
                       value="{{ config.dingtalk_appkey }}" placeholder="dingxxxxxxxxxxxx">
              </div>
              <div class="col-md-4">
                <label class="form-label">AppSecret <small class="text-muted">（加密存储，留空不修改）</small></label>
                <input type="password" name="dingtalk_appsecret" class="form-control form-control-sm"
                       placeholder="{{ config.dingtalk_appsecret ? '已设置' : '请输入' }}">
              </div>
              <div class="col-md-4">
                <label class="form-label">AgentID <small class="text-muted">（工作通知用）</small></label>
                <input type="text" name="dingtalk_agentid" class="form-control form-control-sm font-monospace"
                       value="{{ config.dingtalk_agentid }}" placeholder="12345678">
              </div>
            </div>
            <div class="form-text text-muted mt-1">
              前往 <a href="https://open-dev.dingtalk.com/" target="_blank">钉钉开发者后台</a>
              创建企业内部应用，开启「通讯录只读权限」。
            </div>
          </div>
        </div>

        {# ── 飞书 ── #}
        <div class="card mb-3 border-secondary">
          <div class="card-header py-2 d-flex align-items-center gap-2">
            <div class="form-check form-switch mb-0">
              <input class="form-check-input" type="checkbox" name="feishu_enabled" value="1" id="feishu_enabled"
                     {{ config.feishu_enabled == '1' ? 'checked' : '' }}>
              <label class="form-check-label fw-semibold" for="feishu_enabled">
                <i class="ti ti-message-dots text-info me-1"></i>飞书
              </label>
            </div>
            <button type="button" class="btn btn-xs btn-outline-secondary ms-auto"
                    onclick="testIMConn('feishu')">测试连接</button>
            <span id="test_feishu_result" class="small"></span>
          </div>
          <div class="card-body">
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label">App ID</label>
                <input type="text" name="feishu_appid" class="form-control form-control-sm font-monospace"
                       value="{{ config.feishu_appid }}" placeholder="cli_xxxxxxxxxxxx">
              </div>
              <div class="col-md-6">
                <label class="form-label">App Secret <small class="text-muted">（加密存储，留空不修改）</small></label>
                <input type="password" name="feishu_appsecret" class="form-control form-control-sm"
                       placeholder="{{ config.feishu_appsecret ? '已设置' : '请输入' }}">
              </div>
            </div>
            <div class="form-text text-muted mt-1">
              前往 <a href="https://open.feishu.cn/app" target="_blank">飞书开放平台 → 企业自建应用</a>，
              开启「通讯录读取权限」（contact:user:readonly、contact:department:readonly）。
            </div>
          </div>
        </div>

        {# ── 邮件通知 ── #}
        <h5 class="border-bottom pb-2 mt-4">
          <i class="ti ti-mail me-2"></i>入职通知邮件
          <small class="text-muted fw-normal fs-6 ms-2">新员工创建后发送账号信息</small>
        </h5>
        <div class="row g-3">
          <div class="col-md-6">
            <label class="form-label fw-semibold">通知接收邮箱</label>
            <input type="email" name="im_notify_email" class="form-control form-control-sm"
                   value="{{ config.im_notify_email }}" placeholder="hr@corp.com">
            <div class="form-text">新员工入职时，账号信息发送到此邮箱</div>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-semibold">发件人地址</label>
            <input type="email" name="im_notify_from" class="form-control form-control-sm"
                   value="{{ config.im_notify_from }}" placeholder="noreply@corp.com">
          </div>
          <div class="col-md-5">
            <label class="form-label fw-semibold">SMTP 服务器</label>
            <input type="text" name="im_notify_smtp_host" class="form-control form-control-sm"
                   value="{{ config.im_notify_smtp_host }}" placeholder="smtp.exmail.qq.com">
          </div>
          <div class="col-md-2">
            <label class="form-label fw-semibold">端口</label>
            <input type="number" name="im_notify_smtp_port" class="form-control form-control-sm"
                   value="{{ config.im_notify_smtp_port ?: '465' }}">
          </div>
          <div class="col-md-3">
            <label class="form-label fw-semibold">SMTP 账号</label>
            <input type="text" name="im_notify_smtp_user" class="form-control form-control-sm"
                   value="{{ config.im_notify_smtp_user }}" placeholder="noreply@corp.com">
          </div>
          <div class="col-md-2 d-flex align-items-end pb-1">
            <div class="form-check form-switch">
              <input type="hidden" name="im_notify_smtp_ssl" value="0">
              <input class="form-check-input" type="checkbox" name="im_notify_smtp_ssl" value="1"
                     id="im_smtp_ssl" {{ config.im_notify_smtp_ssl != '0' ? 'checked' : '' }}>
              <label class="form-check-label small" for="im_smtp_ssl">SSL/TLS</label>
            </div>
          </div>
          <div class="col-md-4">
            <label class="form-label fw-semibold">SMTP 密码 <small class="text-muted">（留空不修改）</small></label>
            <input type="password" name="im_notify_smtp_pass" class="form-control form-control-sm"
                   placeholder="{{ config.im_notify_smtp_pass ? '已设置' : '请输入' }}">
          </div>
          <div class="col-auto d-flex align-items-end">
            <button type="button" class="btn btn-sm btn-outline-secondary"
                    onclick="testMailConn()">测试邮件发送</button>
            <span id="test_mail_result" class="small ms-2"></span>
          </div>
          <div class="col-md-4">
            <label class="form-label fw-semibold">通知触发</label>
            <div class="d-flex gap-3 mt-1">
              <div class="form-check">
                <input type="hidden" name="im_notify_on_create" value="0">
                <input class="form-check-input" type="checkbox" name="im_notify_on_create" value="1"
                       id="notify_create" {{ config.im_notify_on_create != '0' ? 'checked' : '' }}>
                <label class="form-check-label small" for="notify_create">新建用户时</label>
              </div>
              <div class="form-check">
                <input type="hidden" name="im_notify_on_disable" value="0">
                <input class="form-check-input" type="checkbox" name="im_notify_on_disable" value="1"
                       id="notify_disable" {{ config.im_notify_on_disable != '0' ? 'checked' : '' }}>
                <label class="form-check-label small" for="notify_disable">禁用用户时</label>
              </div>
            </div>
          </div>
        </div>

        <h5 class="border-bottom pb-2 mt-4">业务参数</h5>
        <div class="row g-3">
          <div class="col-md-3">
            <label class="form-label">差异报告警告天数</label>
            <input type="number" name="diff_alert_days" class="form-control" value="{{ config.diff_alert_days }}" min="1" max="90">
            <div class="form-text">超过此天数未同步时仪表盘高亮警告</div>
          </div>
        </div>

        <div class="mb-3">
          <label class="form-label fw-bold">AD 缓存自动同步间隔</label>
          <select name="ad_sync_interval" class="form-select form-select-sm">
            <option value="0"     {% if config.ad_sync_interval == '0'     %}selected{% endif %}>禁用自动同步</option>
            <option value="3600"  {% if config.ad_sync_interval == '3600'  %}selected{% endif %}>每 1 小时</option>
            <option value="10800" {% if config.ad_sync_interval == '10800' %}selected{% endif %}>每 3 小时</option>
            <option value="21600" {% if config.ad_sync_interval == '21600' %}selected{% endif %}>每 6 小时（默认）</option>
            <option value="43200" {% if config.ad_sync_interval == '43200' %}selected{% endif %}>每 12 小时</option>
            <option value="86400" {% if config.ad_sync_interval == '86400' %}selected{% endif %}>每 24 小时</option>
          </select>
          <div class="form-text text-muted">AD 数据缓存到数据库，搜索直接走 DB，避免每次实时连 AD</div>
        </div>

        <div class="mt-4">
          <button type="submit" name="save" class="btn btn-primary">
            <i class="ti ti-device-floppy me-1"></i>保存配置
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

{# ── AD 缓存同步状态卡片（全宽） ── #}
<div class="row mt-4">
  <div class="col-12">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <span class="fw-bold"><i class="ti ti-database me-1"></i>AD 数据缓存</span>
        <div class="d-flex align-items-center gap-2">
          <span id="syncStatusBadge" class="badge bg-secondary">检查中…</span>
          <button id="syncBtn" class="btn btn-sm btn-primary" onclick="triggerSync()">
            <i class="ti ti-refresh me-1"></i>立即同步
          </button>
        </div>
      </div>
      <div class="card-body">
        <div class="row g-3 text-center" id="syncStats">
          <div class="col-4">
            <div class="border rounded py-2">
              <div class="fs-4 fw-bold text-primary" id="statUsers">—</div>
              <div class="small text-muted">缓存用户</div>
            </div>
          </div>
          <div class="col-4">
            <div class="border rounded py-2">
              <div class="fs-4 fw-bold text-info" id="statComputers">—</div>
              <div class="small text-muted">缓存计算机</div>
            </div>
          </div>
          <div class="col-4">
            <div class="border rounded py-2">
              <div class="fs-4 fw-bold text-secondary" id="statDuration">—</div>
              <div class="small text-muted">上次耗时(s)</div>
            </div>
          </div>
        </div>
        <div class="mt-3 small text-muted" id="syncMeta">加载中…</div>
        <div class="mt-2" id="syncLog">
          <div class="alert alert-sm py-1 px-2 small" id="syncLogMsg"></div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
(function(){
  function loadStatus() {
    fetch('/plugins/admanager/ajax/ad_sync.php?action=status')
      .then(function(r){ return r.json(); }).then(function(d){
        document.getElementById('statUsers').textContent     = d.user_count    ?? '—';
        document.getElementById('statComputers').textContent = d.computer_count ?? '—';
        document.getElementById('statDuration').textContent  = d.duration_sec   ?? '—';

        var badge = document.getElementById('syncStatusBadge');
        if (d.syncing) {
          badge.className = 'badge bg-warning text-dark';
          badge.textContent = '同步中…';
          setTimeout(loadStatus, 3000);
        } else if (!d.last_sync) {
          badge.className = 'badge bg-danger';
          badge.textContent = '从未同步';
        } else if (d.needs_sync) {
          badge.className = 'badge bg-warning text-dark';
          badge.textContent = '需要同步';
        } else {
          badge.className = 'badge bg-success';
          badge.textContent = '缓存正常';
        }

        var meta = d.last_sync
          ? '上次同步：' + d.last_sync + '　触发：' + (d.triggered_by||'—')
          : '尚未执行过同步，搜索将返回空结果';
        document.getElementById('syncMeta').textContent = meta;
      }).catch(function(){ document.getElementById('syncMeta').textContent = '状态加载失败'; });
  }

  window.triggerSync = function() {
    var btn = document.getElementById('syncBtn');
    var csrfVal = (document.querySelector('[name="_glpi_csrf_token"]') || {}).value || '';
    btn.disabled = true;
    btn.innerHTML = '<i class="ti ti-loader-2 ti-spin me-1"></i>同步中…';
    document.getElementById('syncLog').style.display = 'none';

    var fd = new FormData();
    fd.append('_glpi_csrf_token', csrfVal);
    fd.append('action', 'sync');
    fetch('/plugins/admanager/ajax/ad_sync.php', {
      method: 'POST',
      body: fd,
      headers: { 'X-Glpi-Csrf-Token': csrfVal }
    }).then(function(r){ return r.json(); }).then(function(d){
      var log = document.getElementById('syncLogMsg');
      log.className = 'alert py-1 px-2 small ' + (d.ok ? 'alert-success' : 'alert-danger');
      log.textContent = d.message;
      document.getElementById('syncLog').style.display = '';
      btn.disabled = false;
      btn.innerHTML = '<i class="ti ti-refresh me-1"></i>立即同步';
      loadStatus();
    }).catch(function(){
      document.getElementById('syncLogMsg').textContent = '请求失败';
      document.getElementById('syncLog').style.display = '';
      btn.disabled = false;
      btn.innerHTML = '<i class="ti ti-refresh me-1"></i>立即同步';
    });
  };

  loadStatus();
})();
</script>

<script>
// 全局 CSRF token，与 usertemplate 同一套续签机制
var _cfgCSRF = (document.querySelector('[name="_glpi_csrf_token"]')||{}).value||'';

function _imFetch(body) {
  return fetch('/plugins/admanager/ajax/im.php?action=test_connect', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'X-Requested-With': 'XMLHttpRequest',
      'X-Glpi-Csrf-Token': _cfgCSRF
    },
    body: JSON.stringify(body)
  }).then(function(r) {
    return r.json().then(function(d) {
      // 续签 token（与 usertemplate 同一套机制）
      if (d.csrf_token) {
        _cfgCSRF = d.csrf_token;
        var hidden = document.querySelector('[name="_glpi_csrf_token"]');
        if (hidden) hidden.value = _cfgCSRF;
      }
      return d;
    });
  });
}

