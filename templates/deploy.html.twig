<script>
(function(){
  // ── 任务进度自动轮询（5s，有活跃任务时）─────────────────────────────────
  var POLL_INTERVAL = 5000;
  var pollTimer = null;

  function hasActiveTasks() {
    return document.querySelectorAll('[data-task-status="pending"],[data-task-status="running"]').length > 0;
  }

  function updateTaskRow(task) {
    var prog = task.progress || {};
    var total = prog.total || 0;
    var row = document.querySelector('[data-task-id="' + task.id + '"]');
    if (!row) return;

    // 进度条
    var bar = row.querySelector('.progress-bar.bg-success');
    var barFail = row.querySelector('.progress-bar.bg-danger');
    if (bar && total > 0) {
      bar.style.width = Math.round(prog.success / total * 100) + '%';
      if (barFail) barFail.style.width = Math.round(prog.failed / total * 100) + '%';
    }

    // 状态文字 / 角标
    var statusCell = row.querySelector('.task-status-badge');
    if (statusCell) {
      var pend = (prog.pending||0) + (prog.running||0);
      if (pend > 0) {
        statusCell.innerHTML = '<span class="badge bg-warning text-dark"><i class="ti ti-loader-2 ti-spin"></i> 执行中 ' + pend + '/' + total + '</span>';
        row.dataset.taskStatus = 'running';
      } else if ((prog.failed||0) > 0 && (prog.success||0) === 0) {
        statusCell.innerHTML = '<span class="badge bg-danger">全部失败</span>';
        row.dataset.taskStatus = 'done';
      } else if ((prog.failed||0) > 0) {
        statusCell.innerHTML = '<span class="badge bg-warning text-dark"><i class="ti ti-alert-triangle"></i> 部分失败 ' + (prog.success||0) + '/' + total + '</span>';
        row.dataset.taskStatus = 'done';
      } else {
        statusCell.innerHTML = '<span class="badge bg-success"><i class="ti ti-check"></i> 完成 ' + (prog.success||0) + '/' + total + '</span>';
        row.dataset.taskStatus = 'done';
      }
    }
  }

  function pollTasks() {
    if (!hasActiveTasks()) { stopPoll(); return; }
    fetch(window.location.pathname + '?_ajax=task_progress', {
      headers: { 'X-Requested-With': 'XMLHttpRequest' }
    })
    .then(function(r){ return r.json(); })
    .then(function(tasks){
      tasks.forEach(updateTaskRow);
      if (!hasActiveTasks()) stopPoll();
    })
    .catch(function(){});
  }

  function startPoll() {
    if (pollTimer) return;
    pollTimer = setInterval(pollTasks, POLL_INTERVAL);
  }

  function stopPoll() {
    if (pollTimer) { clearInterval(pollTimer); pollTimer = null; }
  }

  if (hasActiveTasks()) startPoll();
})();
</script>
