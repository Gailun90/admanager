<div class="adm-page">

  {# ── 顶部工具栏 ── #}
  <div class="adm-toolbar">
    <div class="adm-toolbar-title">
      <a href="/plugins/admanager/front/deploy.php" class="btn btn-sm btn-outline-secondary">
        <i class="ti ti-arrow-left me-1"></i>返回部署页
      </a>
      <span><i class="ti ti-folders me-1"></i>终端分组管理</span>
    </div>
    <div class="adm-toolbar-actions">
      {% if can_write %}
      <button class="btn btn-sm btn-primary" id="btnNewGroup">
        <i class="ti ti-plus me-1"></i>新建分组
      </button>
      {% endif %}
    </div>
  </div>

  {# ── 分组选择卡 ── #}
  <div class="card mb-2">
    <div class="card-body py-2">
      <div class="row g-2 align-items-end">
        <div class="col-md-3">
          <label class="form-label small fw-bold mb-0">分组名称</label>
          <input type="text" id="groupName" class="form-control" placeholder="新建或编辑名称">
        </div>
        <div class="col-md-5">
          <label class="form-label small fw-bold mb-0">选择分组</label>
          <select id="groupSelect" class="form-select">
            <option value="">— 选择已有分组 —</option>
          </select>
        </div>
        <div class="col-auto">
          {% if can_write %}
          <button class="btn btn-sm btn-success" id="btnSaveGroup"><i class="ti ti-device-floppy me-1"></i>保存分组</button>
          <button class="btn btn-sm btn-outline-danger" id="btnDeleteGroup" disabled><i class="ti ti-trash me-1"></i>删除</button>
          {% endif %}
        </div>
      </div>
    </div>
  </div>

  {# ── 双面板：可用终端 ↔ 分组成员 ── #}
  <div class="row g-2" id="memberPanel" style="display:none">
    <div class="col-md-6">
      <div class="card border-secondary h-100">
        <div class="card-header bg-light py-2 d-flex justify-content-between align-items-center">
          <h6 class="mb-0"><i class="ti ti-devices me-1"></i>可用终端 <span class="badge bg-secondary ms-1" id="availCount">0</span></h6>
          <small class="text-muted">点击 → 加入分组</small>
        </div>
        <div class="card-body p-0">
          <div class="p-2">
            <input type="text" id="availSearch" class="form-control form-control-sm" placeholder="搜索主机名或序列号…">
          </div>
          <div class="overflow-auto" style="height:calc(100vh - 360px);overflow-y:auto" id="availList">
            <div class="text-center text-muted py-4" id="availPlaceholder">加载中…</div>
          </div>
        </div>
      </div>
    </div>
    <div class="col-md-6">
      <div class="card border-success h-100">
        <div class="card-header bg-success bg-opacity-10 py-2 d-flex justify-content-between align-items-center">
          <h6 class="mb-0"><i class="ti ti-checkbox me-1"></i>分组成员 <span class="badge bg-success ms-1" id="memberCount">0</span></h6>
          <small class="text-muted">点击 ✕ 移出分组</small>
        </div>
        <div class="card-body p-0">
          <div class="p-2">
            <input type="text" id="memberSearch" class="form-control form-control-sm" placeholder="过滤已选成员…">
          </div>
          <div class="overflow-auto" style="height:calc(100vh - 360px);overflow-y:auto" id="memberList">
            <div class="text-center text-muted py-4" id="memberPlaceholder">
              <i class="ti ti-arrow-left" style="font-size:1.5rem"></i>
              <p class="mt-1 small">从左侧点击终端加入分组</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
(function(){
  var CAN_WRITE  = {{ can_write ? 'true' : 'false' }};
  var CSRF_TOKEN = {{ csrf_token|json_encode|raw }};

  var allGroups   = [];
  var allClients  = [];
  var currentGid  = null;
  var memberIds   = {};
  var memberData  = {};

  function esc(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

  // ── 数据加载 ──
  function loadGroups() {
    fetch('/plugins/admanager/ajax/groups_data.php?action=groups')
      .then(function(r){ return r.json(); })
      .then(function(d){ allGroups = d||[]; renderGroupSelect(); });
  }
  function loadClients() {
    fetch('/plugins/admanager/ajax/groups_data.php?action=clients')
      .then(function(r){ return r.json(); })
      .then(function(d){ allClients = d||[]; if (currentGid) renderPanels(); });
  }
  function loadMembers(gid) {
    fetch('/plugins/admanager/ajax/groups_data.php?action=members&group_id=' + gid)
      .then(function(r){ return r.json(); })
      .then(function(d){
        memberIds = {}; memberData = {};
        (d||[]).forEach(function(m){
          memberIds[m.id] = true;
          memberData[m.id] = { hostname: m.hostname, serial: m.serial };
        });
        renderPanels();
      });
  }

  function loadGroupData(gid) {
    currentGid = gid;
    var panel = document.getElementById('memberPanel');
    var delBtn = document.getElementById('btnDeleteGroup');
    if (gid) {
      panel.style.display = '';
      delBtn.disabled = false;
      loadMembers(gid);
    } else {
      panel.style.display = 'none';
      delBtn.disabled = true;
      memberIds = {}; memberData = {};
    }
  }

  // ── 渲染 ──
  function renderGroupSelect() {
    var sel = document.getElementById('groupSelect');
    sel.innerHTML = '<option value="">— 选择已有分组 —</option>';
    allGroups.forEach(function(g){
      sel.innerHTML += '<option value="'+g.id+'">'+esc(g.name)+' ('+g.client_count+' 台)'+(g.description?' · '+esc(g.description):'')+'</option>';
    });
  }

  function renderPanels() { renderAvail(); renderMembers(); updateCounts(); }

  function renderAvail(query) {
    var q = (query||'').toLowerCase();
    var list = allClients.filter(function(c){ return !memberIds[c.id] && (!q||c.hostname.toLowerCase().includes(q)||c.serial.toLowerCase().includes(q)); });
    var h = '';
    if (!list.length) {
      h = '<div class="text-center text-muted py-3 small">'+(q?'无匹配':'所有终端已加入分组')+'</div>';
    } else {
      list.forEach(function(c){
        h += '<div class="avail-item d-flex align-items-center px-2 py-1 border-bottom" data-id="'+c.id+'" style="cursor:pointer" title="加入分组">'+
          '<i class="ti ti-arrow-right text-primary me-2"></i>'+
          '<div><span class="fw-semibold small">'+esc(c.hostname)+'</span>'+
          '<small class="text-muted ms-2">'+esc((c.serial||'').substring(0,24))+'</small></div></div>';
      });
    }
    document.getElementById('availList').innerHTML = h;
  }

  function renderMembers(query) {
    var q = (query||'').toLowerCase();
    var list = Object.keys(memberIds).map(function(id){ return {id:parseInt(id),hostname:memberData[id]?.hostname||id,serial:memberData[id]?.serial||''}; })
      .filter(function(m){ return !q||m.hostname.toLowerCase().includes(q)||m.serial.toLowerCase().includes(q); });
    var h = '';
    if (!list.length) {
      h = '<div class="text-center text-muted py-3 small"><i class="ti ti-arrow-left" style="font-size:1.2rem"></i><p class="mt-1">'+(q?'无匹配':'从左侧点击终端加入分组')+'</p></div>';
    } else {
      list.forEach(function(m){
        h += '<div class="member-item d-flex align-items-center px-2 py-1 border-bottom" data-id="'+m.id+'">'+
          '<i class="ti ti-x text-danger me-2" style="cursor:pointer" title="移出分组"></i>'+
          '<div class="flex-grow-1"><span class="fw-semibold small">'+esc(m.hostname)+'</span>'+
          '<small class="text-muted ms-2">'+esc((m.serial||'').substring(0,24))+'</small></div></div>';
      });
    }
    document.getElementById('memberList').innerHTML = h;
  }

  function updateCounts() {
    document.getElementById('availCount').textContent = allClients.filter(function(c){ return !memberIds[c.id]; }).length;
    document.getElementById('memberCount').textContent = Object.keys(memberIds).length;
  }

  // ── 事件 ──
  document.addEventListener('click', function(e){
    var item = e.target.closest('.avail-item');
    if (!item) return;
    var id = parseInt(item.dataset.id);
    var c = allClients.find(function(x){ return x.id===id; });
    if (c) { memberIds[id]=true; memberData[id]={hostname:c.hostname,serial:c.serial}; renderPanels(); }
  });
  document.addEventListener('click', function(e){
    if (!e.target.closest('.ti-x')) return;
    var item = e.target.closest('.member-item');
    if (!item) return;
    var id = parseInt(item.dataset.id);
    delete memberIds[id]; delete memberData[id];
    renderPanels();
  });
  document.getElementById('availSearch').addEventListener('input', function(){ renderAvail(this.value); });
  document.getElementById('memberSearch').addEventListener('input', function(){ renderMembers(this.value); });

  document.getElementById('groupSelect').addEventListener('change', function(){
    var gid = parseInt(this.value)||null;
    if (gid) {
      var g = allGroups.find(function(x){ return x.id===gid; });
      document.getElementById('groupName').value = g?g.name:'';
      loadGroupData(gid);
    } else {
      document.getElementById('groupName').value = '';
      loadGroupData(null);
    }
  });

  // ★ 单个 save_all POST 保存分组名+成员
  document.getElementById('btnSaveGroup').addEventListener('click', function(){
    var name = document.getElementById('groupName').value.trim();
    if (!name) { alert('请输入分组名称'); return; }

    var ids = Object.keys(memberIds).join(',');
    var body = '_glpi_csrf_token='+encodeURIComponent(CSRF_TOKEN)+
      '&_action=save_all'+
      '&group_name='+encodeURIComponent(name)+
      '&group_id='+(currentGid||0)+
      '&client_ids='+encodeURIComponent(ids);

    fetch(window.location.href, {
      method: 'POST',
      headers: {'Content-Type':'application/x-www-form-urlencoded'},
      body: body
    }).then(function(){ location.reload(); })
    .catch(function(e){ alert('保存失败，请重试'); console.error(e); });
  });

  document.getElementById('btnNewGroup').addEventListener('click', function(){
    document.getElementById('groupSelect').value = '';
    document.getElementById('groupName').value = '';
    document.getElementById('groupName').focus();
    loadGroupData(null);
  });

  document.getElementById('btnDeleteGroup').addEventListener('click', function(){
    if (!currentGid) return;
    var g = allGroups.find(function(x){ return x.id===currentGid; });
    if (!confirm('确定删除分组\u300c'+(g?g.name:currentGid)+'\u300d？')) return;
    var body = '_glpi_csrf_token='+encodeURIComponent(CSRF_TOKEN)+'&_action=delete_group&group_id='+currentGid;
    fetch(window.location.href, {method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded'},body:body})
      .then(function(){ location.reload(); });
  });

  // ── 初始化 ──
  loadGroups();
  loadClients();
})();
</script>
