<div class="adm-page">
  {# === 操作结果 === #}
  {% if result %}
    <div class="alert alert-{{ result.ok ? 'success' : 'warning' }} mt-2 alert-dismissible fade show">
      <i class="ti ti-{{ result.ok ? 'circle-check' : 'alert-triangle' }} me-1"></i>{{ result.message }}
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  {% endif %}
  {% if error %}
    <div class="alert alert-danger mt-2">{{ error }}</div>
  {% endif %}

  {# === 搜索栏 + 操作按钮（全宽搜索布局） === #}
  <div class="card mb-3">
    <div class="card-body py-2">
      <div class="d-flex justify-content-between align-items-start flex-wrap">
        <form method="get" class="d-flex align-items-end flex-nowrap gap-2">
          <div class="ad-search-input">
            <input type="text" name="keyword" class="form-control form-control-sm" value="{{ keyword }}" placeholder="输入后回车搜索（账号/姓名/邮箱）...">
          </div>
          <div class="ad-search-input">
            <input type="text" name="ou" class="form-control form-control-sm" id="searchOuInput" placeholder="过滤 OU（可选）" value="{{ ou }}">
          </div>
          <div class="ad-search-btn">
            <button type="submit" name="search" class="btn btn-sm btn-primary"><i class="ti ti-search me-1"></i>搜索</button>
          </div>
        </form>
        <div class="mt-1">
          {% if can_create %}
            <button class="btn btn-sm btn-success me-1" data-bs-toggle="collapse" data-bs-target="#createUserForm">
              <i class="ti ti-user-plus me-1"></i>新建用户
            </button>
            <button class="btn btn-sm btn-outline-success" data-bs-toggle="collapse" data-bs-target="#batchImportForm">
              <i class="ti ti-file-import me-1"></i>批量导入
            </button>
          {% endif %}
          <a href="/plugins/admanager/front/usertemplate.php" class="btn btn-sm btn-outline-secondary ms-1">
            <i class="ti ti-template me-1"></i>模板管理
          </a>
        </div>
      </div>

      {# === 新建用户表单 === #}
      {% if can_create %}
      <div class="collapse mt-3" id="createUserForm">
        <div class="card border-success">
          <div class="card-header bg-success bg-opacity-10 d-flex justify-content-between align-items-center">
            <h6 class="mb-0"><i class="ti ti-user-plus me-1"></i>新建 AD 用户</h6>
            <div class="d-flex align-items-center">
              <label class="form-label small mb-0 me-2">模板：</label>
              <select id="tplSelectCreate" class="form-select form-select-sm" onchange="applyTemplateToForm()">
                {% for t in templates %}
                  <option value="{{ t.id }}" 
                    {% if t.id == tpl_id %}selected{% endif %}
                    data-fields='{{ t.fields|default('[]')|raw }}'>
                    {{ t.name }}
                  </option>
                {% endfor %}
              </select>
              <a href="/plugins/admanager/front/usertemplate.php" class="btn btn-sm btn-outline-secondary ms-1" title="管理模板"><i class="ti ti-settings"></i></a>
            </div>
          </div>
          <div class="card-body">
            <form method="post" id="createUserFormInner">
              <input type="hidden" name="_glpi_csrf_token" value="{{ csrf_token }}">
              <input type="hidden" name="action" value="create_user">

              <div class="row g-2 mb-2">
                <div class="col-md-3">
                  <label class="form-label small fw-bold">登录名 *</label>
                  <input type="text" name="samaccountname" class="form-control form-control-sm" placeholder="zhangsan" required>
                </div>
                <div class="col-md-3">
                  <label class="form-label small fw-bold">显示名 *</label>
                  <input type="text" name="displayname" class="form-control form-control-sm" placeholder="张三" required>
                </div>
                <div class="col-md-3">
                  <label class="form-label small fw-bold">初始密码 *</label>
                  <div class="input-group input-group-sm">
                    <input type="text" name="password" class="form-control form-control-sm" id="create_pwd" placeholder="至少8位" required>
                    <button type="button" class="btn btn-outline-secondary" onclick="genPassword()"><i class="ti ti-dice-5"></i></button>
                  </div>
                </div>
                <div class="col-md-3">
                  <label class="form-label small fw-bold">目标 OU *</label>
                  <div class="input-group input-group-sm">
                    <input type="text" name="ou" class="form-control form-control-sm" id="createOuInput" required placeholder="OU=部门,DC=corp,DC=com">
                      
                    <button type="button" class="btn btn-outline-secondary" onclick="showNewOuModal()" title="新增 OU"><i class="ti ti-plus"></i></button>
                  </div>
                </div>
              </div>

              <div id="optionalFieldsContainer">
                <div class="row g-2 optional-row" data-field="sn">
                  <div class="col-md-3">
                    <label class="form-label small">姓</label>
                    <input type="text" name="sn" class="form-control form-control-sm" placeholder="张">
                  </div>
                </div>
                <div class="row g-2 optional-row" data-field="givenname">
                  <div class="col-md-3">
                    <label class="form-label small">名</label>
                    <input type="text" name="givenname" class="form-control form-control-sm" placeholder="三">
                  </div>
                </div>
                <div class="row g-2 optional-row" data-field="mail">
                  <div class="col-md-4">
                    <label class="form-label small">邮箱</label>
                    <input type="email" name="mail" class="form-control form-control-sm" placeholder="zhangsan@corp.com">
                  </div>
                </div>
                <div class="row g-2 optional-row" data-field="department">
                  <div class="col-md-4">
                    <label class="form-label small">部门</label>
                    <input type="text" name="department" class="form-control form-control-sm" placeholder="技术部">
                  </div>
                </div>
                <div class="row g-2 optional-row" data-field="title">
                  <div class="col-md-3">
                    <label class="form-label small">职位</label>
                    <input type="text" name="title" class="form-control form-control-sm" placeholder="工程师">
                  </div>
                </div>

                <div class="collapse" id="moreFields">
                  <div class="row g-2 mt-0">
                    {% set extra_fields = [
                      {'key':'company','label':'公司','col':'3','type':'text','ph':'公司名'},
                      {'key':'division','label':'分部','col':'3','type':'text','ph':'分部名称'},
                      {'key':'manager','label':'经理(DN)','col':'6','type':'text','ph':'CN=xxx,OU=xxx,DC=xxx'},
                      {'key':'telephonenumber','label':'办公电话','col':'3','type':'text','ph':'021-xxxx'},
                      {'key':'mobile','label':'手机号','col':'3','type':'text','ph':'138xxxx'},
                      {'key':'facsimiletelephonenumber','label':'传真','col':'3','type':'text','ph':'021-xxxx'},
                      {'key':'wWWHomePage','label':'主页','col':'3','type':'url','ph':'https://'},
                      {'key':'streetaddress','label':'街道地址','col':'6','type':'text','ph':'xx路xx号'},
                      {'key':'l','label':'城市','col':'3','type':'text','ph':'上海'},
                      {'key':'st','label':'省份','col':'3','type':'text','ph':'上海'},
                      {'key':'postalcode','label':'邮编','col':'3','type':'text','ph':'200000'},
                      {'key':'co','label':'国家/地区','col':'3','type':'text','ph':'中国'},
                      {'key':'physicaldeliveryofficename','label':'办公室','col':'3','type':'text','ph':'A栋3楼'},
                      {'key':'employeenumber','label':'员工编号','col':'3','type':'text','ph':'EMP001'},
                      {'key':'employeetype','label':'员工类型','col':'3','type':'text','ph':'正式员工'},
                      {'key':'description','label':'描述','col':'6','type':'text','ph':'备注信息'},
                      {'key':'info','label':'备注','col':'6','type':'text','ph':'附加备注'},
                    ] %}
                    {% for f in extra_fields %}
                    <div class="col-md-{{ f.col }} optional-row" data-field="{{ f.key }}">
                      <label class="form-label small">{{ f.label }}</label>
                      <input type="{{ f.type }}" name="{{ f.key }}" class="form-control form-control-sm" placeholder="{{ f.ph }}">
                    </div>
                    {% endfor %}
                  </div>
                </div>
                <div class="mt-1">
                  <button type="button" class="btn btn-sm btn-link p-0" data-bs-toggle="collapse" data-bs-target="#moreFields" id="btnMoreFields">
                    <i class="ti ti-chevron-down me-1"></i><span id="btnMoreFieldsText">展开更多字段</span>
                  </button>
                </div>
              </div>

              <div class="mt-2">
                <button type="submit" class="btn btn-success btn-sm"><i class="ti ti-check me-1"></i>创建用户</button>
                <small class="text-muted ms-2">密码需满足域策略要求；用户首次登录将强制修改密码</small>
              </div>
            </form>
          </div>
        </div>
      </div>

      {# === 批量导入 === #}
      <div class="collapse mt-2" id="batchImportForm">
        <div class="card border-info">
          <div class="card-header bg-info bg-opacity-10"><h6 class="mb-0"><i class="ti ti-file-spreadsheet me-1"></i>批量导入 AD 用户（CSV）</h6></div>
          <div class="card-body">
            <form method="post" enctype="multipart/form-data">
              <input type="hidden" name="_glpi_csrf_token" value="{{ csrf_token }}">
              <input type="hidden" name="action" value="batch_import">
              <div class="row g-2 align-items-end">
                <div class="col-md-5">
                  <label class="form-label small fw-bold">选择 CSV 文件</label>
                  <input type="file" name="csv_file" class="form-control form-control-sm" accept=".csv" required>
                </div>
                <div class="col-md-4">
                  <label class="form-label small">默认 OU（CSV 未指定时）</label>
                  <input type="text" name="default_ou" class="form-control form-control-sm" id="csvDefaultOuInput" placeholder="OU=部门,DC=corp,DC=com">
                </div>
                <div class="col-auto">
                  <button type="submit" class="btn btn-info btn-sm"><i class="ti ti-upload me-1"></i>开始导入</button>
                </div>
              </div>
              <div class="mt-2 small text-muted">
                CSV 格式：samaccountname,displayname,password,givenname,sn,ou,mail,department,company,title
                <br>第一行为标题行；密码列必填；每行一个用户
                <br><a href="javascript:downloadCsvTemplate()" class="text-decoration-none">
                  <i class="ti ti-download me-1"></i>下载 CSV 导入模板（含 OU 列）
                </a>
              </div>
            </form>
          </div>
        </div>
      </div>
      {% endif %}
    </div>
  </div>

  {# === 搜索结果表格 === #}
  {% if users is not empty %}
  <div class="card mt-2">
    <div class="card-header d-flex justify-content-between align-items-center">
      <h6 class="mb-0">搜索结果（{{ users|length }} 条）</h6>
    </div>
    <div class="table-responsive">
      <div class="ad-table-wrap">
<table class="table adm-table table-hover table-sm mb-0 align-middle">
        <thead class="table-light">
          <tr><th>账号</th><th>显示名</th><th>邮箱</th><th>部门</th><th>状态</th><th>最后登录</th><th>操作</th></tr>
        </thead>
        <tbody>
          {% for u in users %}
          <tr>
            <td>
              <a href="?keyword={{ keyword }}&detail={{ u.samaccountname }}" class="fw-bold">{{ u.samaccountname }}</a>
            </td>
            <td>
              {{ u.displayname ?? '—' }}
              {% set ims = u.im_bindings|default([]) %}
              {% if ims is not empty %}
                <br><small class="text-primary">{{ ims|join(' ') }}</small>
              {% endif %}
            </td>
            <td class="small text-muted">{{ u.mail ?? '—' }}</td>
            <td class="small">{{ u.department ?? '—' }}</td>
            <td>
              {% if u.is_disabled ?? false %}<span class="badge bg-secondary">已禁用</span>
              {% elseif u.is_locked ?? false %}<span class="badge bg-warning text-dark">已锁定</span>
              {% else %}<span class="badge bg-success">正常</span>{% endif %}
            </td>
            <td class="small text-muted">{% if u.last_logon_unix is defined %}{{ u.last_logon_unix|date('Y-m-d') }}{% else %}—{% endif %}</td>
            <td>
              <div class="btn-group btn-group-sm">
                {% if can_write %}
                  {% if u.is_disabled ?? false %}
                    <button class="btn btn-outline-success btn-xs ad-action" data-action="enable" data-dn="{{ u.dn }}" data-name="{{ u.displayname }}" data-sam="{{ u.samaccountname }}" title="启用"><i class="ti ti-player-play"></i></button>
                  {% else %}
                    <button class="btn btn-outline-secondary btn-xs ad-action" data-action="disable" data-dn="{{ u.dn }}" data-name="{{ u.displayname }}" data-sam="{{ u.samaccountname }}" title="禁用"><i class="ti ti-player-pause"></i></button>
                  {% endif %}
                  {% if u.is_locked ?? false %}
                    <button class="btn btn-outline-warning btn-xs ad-action" data-action="unlock" data-dn="{{ u.dn }}" data-name="{{ u.displayname }}" title="解锁"><i class="ti ti-lock-open"></i></button>
                  {% endif %}
                {% endif %}
                {% if can_reset %}
                  <button class="btn btn-outline-danger btn-xs" title="重置密码" onclick="showReset('{{ u.dn }}','{{ u.displayname }}')"><i class="ti ti-key"></i></button>
                {% endif %}
                <a href="?keyword={{ keyword }}&detail={{ u.samaccountname }}" class="btn btn-outline-info btn-xs" title="详情"><i class="ti ti-eye"></i></a>
                {% if can_create %}
                  <button class="btn btn-outline-primary btn-xs ad-action" data-action="import_to_glpi" data-dn="{{ u.dn }}" data-samaccountname="{{ u.samaccountname }}" data-name="{{ u.displayname }}" title="导入GLPI"><i class="ti ti-file-import"></i></button>
                {% endif %}
              </div>
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
</div>
    </div>
  </div>
  {% elseif keyword is not empty and detail_user is null %}
    <div class="alert alert-info mt-3">未找到匹配用户</div>
  {% endif %}

  {# === 用户详情弹窗 === #}
  {% if detail_user %}
  <div class="card mt-2 border-info">
    <div class="card-header bg-info bg-opacity-10 d-flex justify-content-between align-items-center">
      <h5 class="mb-0"><i class="ti ti-user-circle me-1"></i>用户详情：{{ detail_user.samaccountname }}</h5>
      <a href="?" class="btn btn-sm btn-outline-secondary">关闭</a>
    </div>
    <div class="card-body">
      <div class="row g-3">
        <div class="col-md-6">
          <div class="ad-table-wrap">
<table class="table adm-table table-sm table-borderless mb-0">
            <tr><td class="text-muted">登录名</td><td><code>{{ detail_user.samaccountname }}</code></td></tr>
            <tr><td class="text-muted">显示名</td><td>{{ detail_user.displayname ?? '—' }}</td></tr>
            <tr><td class="text-muted">姓 / 名</td><td>{{ detail_user.sn ?? '—' }} / {{ detail_user.givenname ?? '—' }}</td></tr>
            <tr><td class="text-muted">邮箱</td><td>{{ detail_user.mail ?? '—' }}</td></tr>
            <tr>
              <td class="text-muted">IM 绑定</td>
              <td>
                {% set ims = detail_user.im_bindings|default([]) %}
                {% if ims is not empty %}
                  {% for im in ims %}<span class="badge bg-primary-subtle text-primary me-1">{{ im }}</span>{% endfor %}
                {% else %}<span class="text-muted small">—</span>{% endif %}
              </td>
            </tr>
            <tr><td class="text-muted">电话</td><td>{{ detail_user.telephonenumber ?? '—' }}</td></tr>
            <tr><td class="text-muted">部门</td><td>{{ detail_user.department ?? '—' }}</td></tr>
            <tr><td class="text-muted">职位</td><td>{{ detail_user.title ?? '—' }}</td></tr>
            <tr><td class="text-muted">公司</td><td>{{ detail_user.company ?? '—' }}</td></tr>
            <tr><td class="text-muted">办公室</td><td>{{ detail_user.physicaldeliveryofficename ?? '—' }}</td></tr>
            <tr><td class="text-muted">经理</td><td>{{ detail_user.manager ?? '—' }}</td></tr>
          </table>
</div>
        </div>
        <div class="col-md-6">
          <div class="ad-table-wrap">
<table class="table adm-table table-sm table-borderless mb-0">
            <tr><td class="text-muted">DN</td><td class="small">{{ detail_user.dn }}</td></tr>
            <tr><td class="text-muted">UPN</td><td class="small">{{ detail_user.userprincipalname ?? '—' }}</td></tr>
            <tr><td class="text-muted">账号状态</td><td>
              {% if detail_user.is_disabled ?? false %}<span class="badge bg-danger">已禁用</span>
              {% elseif detail_user.is_locked ?? false %}<span class="badge bg-warning text-dark">已锁定</span>
              {% else %}<span class="badge bg-success">正常</span>{% endif %}
            </td></tr>
            <tr><td class="text-muted">UAC</td><td><code>{{ detail_user.useraccountcontrol ?? '—' }}</code></td></tr>
            <tr><td class="text-muted">最后登录</td><td>{{ detail_user.last_logon_fmt ?? '—' }}</td></tr>
            <tr><td class="text-muted">距今天数</td><td>{% if detail_user.last_logon_days is defined %}{{ detail_user.last_logon_days }} 天前{% else %}—{% endif %}</td></tr>
            <tr><td class="text-muted">密码最后设置</td><td>{{ detail_user.pwdlastset_fmt ?? '—' }}</td></tr>
            <tr><td class="text-muted">密码已用天数</td><td>{% if detail_user.pwd_age_days is defined %}{{ detail_user.pwd_age_days }} 天{% else %}—{% endif %}</td></tr>
            <tr><td class="text-muted">创建时间</td><td>{{ detail_user.whencreated ?? '—' }}</td></tr>
            <tr><td class="text-muted">修改时间</td><td>{{ detail_user.whenchanged ?? '—' }}</td></tr>
          </table>
</div>
        </div>
        {% if detail_user.groups is defined and detail_user.groups is not empty %}
        <div class="col-12">
          <h6 class="mb-2">组成员（{{ detail_user.groups|length }} 个）</h6>
          <div class="d-flex flex-wrap gap-1">
            {% for g in detail_user.groups %}
              <span class="badge bg-light text-dark border">{{ g }}</span>
            {% endfor %}
          </div>
        </div>
        {% endif %}
      </div>
    </div>
  </div>
  {% endif %}

  {# === 新增 OU 弹窗 === #}
  <div class="modal fade" id="newOuModal" tabindex="-1">
    <div class="modal-dialog modal-sm"><div class="modal-content">
      <div class="modal-header"><h5 class="modal-title"><i class="ti ti-plus me-1"></i>新增 OU</h5></div>
      <div class="modal-body">
        <label class="form-label small fw-bold">OU 名称</label>
        <input type="text" id="newOuName" class="form-control form-control-sm" placeholder="例如：技术部">
        <small class="text-muted mt-1">将在 AD 根目录下创建新的组织单位</small>
      </div>
      <div class="modal-footer">
        <button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">取消</button>
        <button class="btn btn-primary btn-sm" onclick="createNewOu()">创建</button>
      </div>
    </div></div>
  </div>

  {# === 密码重置弹窗 === #}
  <div class="modal fade" id="resetModal" tabindex="-1">
    <div class="modal-dialog modal-sm"><div class="modal-content">
      <div class="modal-header"><h5 class="modal-title">重置密码</h5></div>
      <div class="modal-body">
        <p class="small text-muted" id="reset_name"></p>
        <div class="input-group input-group-sm">
          <input type="text" id="new_pwd" class="form-control" placeholder="新密码（至少8位）">
          <button class="btn btn-outline-secondary" type="button" onclick="genResetPwd()"><i class="ti ti-dice-5"></i></button>
        </div>
        <div id="reset_msg" class="mt-2 small"></div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">取消</button>
        <button class="btn btn-danger btn-sm" onclick="doReset()">确认重置</button>
      </div>
    </div></div>
  </div>
  <div id="toast_wrap" class="position-fixed bottom-0 end-0 p-3"></div>
</div>

<script>
// -- AD User Operations --
var CSRF='{{ csrf_token }}', FORM='/plugins/admanager/front/aduser.form.php';

// Update CSRF token after each fetch
function apiFetch(url, opts) {
  opts = opts || {};
  return fetch(url, opts).then(function(r) {
    return r.json().then(function(d) { return d; });
  });
}


// ad-action event delegation (handles dynamically created buttons too)
document.addEventListener('click',function(e){
  var btn = e.target.closest('.ad-action');
  if(!btn) return;
  e.preventDefault();
  var row = btn.closest('tr');
  if(!confirm('\u786e\u8ba4\u300c'+btn.dataset.action+'\u300d\u64cd\u4f5c\uff1a'+btn.dataset.name+'\uff1f\u300d')) return;
  var fd=new FormData(); fd.append('_glpi_csrf_token',CSRF);
  Object.entries(btn.dataset).forEach(function(e){ fd.append(e[0],e[1]); });
  btn.disabled=true;
  apiFetch(FORM,{method:'POST',body:fd}).then(function(d){
    toast(d.ok,d.message);
    // update UI after enable/disable
    if(d.ok && (btn.dataset.action==='enable'||btn.dataset.action==='disable') && row){
      // 1) status badge (5th td)
      var badgeTd = row.cells[4];
      if(d.new_state==='disabled'){
        // 已禁用
        if(badgeTd) badgeTd.innerHTML = '<span class="badge bg-secondary">\u5df2\u7981\u7528</span>';
        btn.className = 'btn btn-outline-success btn-xs ad-action';
        btn.dataset.action = 'enable';
        btn.querySelector('i').className = 'ti ti-player-play';
      } else {
        // 已启用（正常）
        if(badgeTd) badgeTd.innerHTML = '<span class="badge bg-success">\u6b63\u5e38</span>';
        btn.className = 'btn btn-outline-secondary btn-xs ad-action';
        btn.dataset.action = 'disable';
        btn.querySelector('i').className = 'ti ti-player-pause';
      }
      // 2) detail view badge (if visible)
      var detailBadge = document.querySelector('.card.border-info .badge.bg-success, .card.border-info .badge.bg-danger, .card.border-info .badge.bg-secondary');
      if(detailBadge){
        detailBadge.className = 'badge ' + (d.new_state==='disabled' ? 'bg-danger' : 'bg-success');
        detailBadge.textContent = d.new_state==='disabled' ? '\u5df2\u7981\u7528' : '\u6b63\u5e38';
      }
    }
    // for unlock / import_to_glpi / other actions, auto-refresh after success
    else if(d.ok && btn.dataset.action==='unlock'){
      setTimeout(function(){location.reload();},600);
    }
    btn.disabled=false;
    if(d.csrf_token) CSRF = d.csrf_token;
  }).catch(function(e){toast(false,e.message||e); btn.disabled=false;});
});
var rdn='';
