async function createNewOu(){
  var name=document.getElementById('newOuName').value.trim();
  if(!name){toast(false,'\u8bf7\u8f93\u5165OU\u540d\u79f0');return;}
  try{
    var fd=new FormData();
    fd.append('_glpi_csrf_token',CSRF);
    fd.append('action','create_ou');
    fd.append('ou_name',name);
    var d=await apiFetch(FORM,{method:'POST',body:fd});
    if(!d.ok){toast(false,d.message);return;}
    var sel=document.getElementById('createOuSelect');
    if(sel){
      var opt=document.createElement('option');
      opt.value=d.data.distinguishedname;
      opt.textContent=d.data.distinguishedname;
      opt.selected=true;
      sel.appendChild(opt);
    }
    bootstrap.Modal.getInstance(document.getElementById('newOuModal')).hide();
    toast(true,d.message);
  }catch(e){toast(false,e.message);}
}

// ======= \u6a21\u677f\u5e94\u7528\u903b\u8f91 =======

function applyTemplateToForm() {
  var sel = document.getElementById('tplSelectCreate');
  var opt = sel && sel.options[sel.selectedIndex];

  // No template selected -> show all fields
  if (!opt || !sel.value || sel.value === '0') {
    showAllOptionalFields();
    clearAllFieldValues();
    return;
  }

  // Hide all + clear values first
  hideAllOptionalFields();
  clearAllFieldValues();

  try {
    var fieldsRaw = opt.dataset.fields || '[]';
    var fields = JSON.parse(fieldsRaw);
    if (typeof fields === 'string') fields = JSON.parse(fields);
    if (!Array.isArray(fields)) fields = [];

    var needsExpand = false;
    fields.forEach(function(f) {
      var key = f.key;
      var def = f.default || '';

      // ── always_fixed \u56fa\u5b9a\u9884\u8bbe\u5b57\u6bb5\uff08ou\uff09\u2014\u2014 \u81ea\u52a8\u586b\u5165 OU \u8f93\u5165\u6846 ──
      if (key === 'ou') {
        if (def) {
          var ouInput = document.getElementById('createOuInput');
          if (ouInput) ouInput.value = def;
        }
        return;
      }

      // ── \u666e\u901a\u53ef\u9009\u5b57\u6bb5 \u2014 \u6309\u6a21\u677f\u663e\u793a\u5e76\u9884\u586b ──
      var row = document.querySelector('.optional-row[data-field="' + key + '"]');
      if (!row) return;

      row.style.display = '';

      // Prefill default (user can modify)
      if (def) {
        var input = row.querySelector('input, select, textarea');
        if (input) {
          if (input.tagName === 'SELECT') {
            Array.from(input.options).forEach(function(o) {
              o.selected = (o.value === def);
            });
          } else {
            input.value = def;
          }
        }
      }

      if (row.closest('#moreFields')) needsExpand = true;
    });

    var moreFields = document.getElementById('moreFields');
    if (needsExpand && moreFields && !moreFields.classList.contains('show')) {
      new bootstrap.Collapse(moreFields, {toggle: true});
    }
  } catch(e) {
    console.warn('applyTemplateToForm error:', e);
    showAllOptionalFields();
  }
}

function hideAllOptionalFields() {
  document.querySelectorAll('.optional-row').forEach(function(row) { row.style.display = 'none'; });
}

function showAllOptionalFields() {
  document.querySelectorAll('.optional-row').forEach(function(row) { row.style.display = ''; });
}

function clearAllFieldValues() {
  document.querySelectorAll('.optional-row input, .optional-row textarea').forEach(function(input) {
    input.value = '';
  });
  document.querySelectorAll('.optional-row select').forEach(function(sel) {
    sel.selectedIndex = 0;
  });
}
